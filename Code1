function summarizeCandidates_(candidates) {
  if (!candidates || candidates.length === 0) return '';
  return candidates
    .slice(0, 5)
    .map((c, idx) => `${idx+1}) ${c.productName} / мҲҳлҹү=${c.qty} / л§Өм¶ң=${c.salesWon}`)
    .join('\n');
}

function findNearTimeCandidates_(dataMap, date, company, timeText) {
  const targetMinutes = timeToMinutes_(timeText);
  if (targetMinutes === null) return '';

  const results = [];

  Object.keys(dataMap).forEach(key => {
    const [kDate, kTime, kCompany] = key.split('|');
    if (kDate !== date || kCompany !== company) return;

    const minutes = timeToMinutes_(kTime);
    if (minutes === null) return;

    const diff = Math.abs(minutes - targetMinutes);
    if (diff <= CONFIG.NEAR_TIME_MINUTES) {
      (dataMap[key] || []).slice(0, 3).forEach(item => {
        results.push({ diff, time: kTime, productName: item.productName, qty: item.qty, salesWon: item.salesWon });
      });
    }
  });

  return results
    .sort((a, b) => a.diff - b.diff)
    .slice(0, 5)
    .map((r, idx) => `${idx+1}) ${r.time} / Вұ${r.diff}л¶„ / ${r.productName} / мҲҳлҹү=${r.qty} / л§Өм¶ң=${r.salesWon}`)
    .join('\n');
}
